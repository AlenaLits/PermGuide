<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/audioCard"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerCityPhotos"
                android:layout_width="match_parent"
                android:layout_height="300dp"/>

            <com.tbuonomo.viewpagerdotsindicator.WormDotsIndicator
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                app:dotsColor="?attr/colorOutline"
                app:selectedDotColor="?attr/colorOnBackground"
                app:dotsSize="10dp"
                app:dotsSpacing="10dp"
                app:dotsStrokeWidth="1dp"
                app:dotsStrokeColor="?attr/colorOutline"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:text="Добро пожаловать в Пермь!"
                android:textColor="?attr/colorOnBackground"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvHomeCityDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:lineSpacingExtra="6dp"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 🎧 АУДИО КАРТОЧКА -->
    <LinearLayout
        android:id="@+id/audioCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="0dp"
        android:background="@drawable/border_white_button"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Верх: текст + кнопка -->
        <RelativeLayout
            android:id="@+id/btnPlayAudioHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Прослушать"
                android:textColor="?attr/colorOnSurface"
                android:textSize="18sp"
                android:layout_centerVertical="true"/>

            <ImageView
                android:id="@+id/playIconId"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_play"
                app:tint="?attr/colorOnSurface"/>
        </RelativeLayout>

        <!-- Прогресс -->
        <SeekBar
            android:id="@+id/audioProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:progressTint="?attr/colorOnSurface"
            android:thumbTint="?attr/colorOnSurface"/>

        <!-- Время -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/textCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="?attr/colorOnSurface"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/textDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>