<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Заливка -->
    <solid android:color="#2B2B2B"/>

    <!-- Скругление -->
    <corners android:radius="10dp"/>

    <!-- Обводка (по желанию) -->
